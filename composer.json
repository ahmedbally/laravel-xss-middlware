{
    "name": "alkhwlani/xss-middleware",
    "description": "A Laravel Middleware to filter user inputs from XSS and iframes and other embed elements.",
    "keywords": ["laravel", "framework", "security", "xss", "Security", "Laravel Security", "Laravel-Security", "middleware", "filter input"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Salah Alkhwlani",
            "email": "alkhwlani@yandex.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "illuminate/http": "^10.0 || ^11.0 || ^12.0 || ^13.0",
        "voku/anti-xss": "^4.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Alkhwlani\\XssMiddleware\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Alkhwlani\\XssMiddleware\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Alkhwlani\\XssMiddleware\\ServiceProvider"
            ]
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true
    }
}
